# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Meta WhatsApp Cloud API ──────────────────────────────
META_PHONE_NUMBER_ID=1113871598486176
META_ACCESS_TOKEN=EAAMoXGkw...
META_VERIFY_TOKEN=platim2024
META_WABA_ID=2124214498439160
# Version del Graph API de Meta (opcional, default v21.0)
META_API_VERSION=v21.0

# ── SMTP de envio ────────────────────────────────────────
# Por defecto usa Gmail. Para enviar DESDE el dominio propio (ventas@platim.co),
# descomenta y completa lo de abajo (correo alojado en Hostinger Email):
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_USER=ventas@platim.co
#   SMTP_PASSWORD=la-contrasena-del-buzon
#   EMAIL_FROM=ventas@platim.co
GMAIL_USER=correo@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Email interno PLATIM (recibe copia de cada cotizacion) ─
PLATIM_EMAIL=ventas@platim.co
# Copias internas adicionales por cotizacion (separadas por coma)
PLATIM_EMAIL_COPIA=info@platim.co

# ── Modelo del agente (opcional) ─────────────────────────
OPENAI_MODEL=gpt-4o-mini

# ── Audio: transcripcion (STT) y voz (TTS) (opcional) ────
STT_MODEL=whisper-1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# ── Mercado Pago (pagos) ─────────────────────────────────
# Token de acceso (usar TEST-... para pruebas en sandbox)
MP_ACCESS_TOKEN=
MP_SANDBOX=true
# URL publica del servidor para el webhook de pago (ej. la del tunel)
PUBLIC_BASE_URL=

# Agrupador de mensajes: segundos de espera (opcional)
DEBOUNCE_SEGUNDOS=6
